# General Configuration
SECRET_KEY=your_secret_key_here
JWT_SECRET_KEY=your_jwt_secret_key_here
MONGO_URI=mongodb://localhost:27017/tech_marketplace
APP_BASE_URL=http://localhost:5000
ENV=development

# Flask-Mail configuration
MAIL_SERVER=localhost
MAIL_PORT=587
MAIL_USE_TLS=True
MAIL_USE_SSL=False
MAIL_USERNAME=your_smtp_username
MAIL_PASSWORD=your_smtp_password
MAIL_SENDER=no-reply@example.com

# Razorpay credentials (leave blank or placeholder for mock sandbox mode)
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=

# Storage settings (cloudinary or local)
STORAGE_BACKEND=local
UPLOAD_FOLDER=uploads

# Cloudinary configuration (required if STORAGE_BACKEND=cloudinary)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Rate Limit configuration
RATE_LIMIT_LOGIN_PER_MIN=10
RATE_LIMIT_REGISTER_PER_MIN=5

# Contact Information Config
CONTACT_PERSON=Mr. Raghuraj
CONTACT_PHONE=+91 9849258028
CONTACT_EMAIL=raghuraj@hotmail.com
